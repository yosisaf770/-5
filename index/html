<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>מחשבון מודרני</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600&display=swap');

        body {
            font-family: 'Assistant', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .calculator-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            width: 100%;
            max-width: 350px;
            padding: 1.5rem;
        }

        .display-screen {
            background-color: #f3f4f6;
            border-radius: 1rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            text-align: left;
            min-height: 100px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            word-break: break-all;
            box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.06);
        }

        .previous-operand {
            color: #6b7280;
            font-size: 1rem;
            height: 1.5rem;
        }

        .current-operand {
            color: #1f2937;
            font-size: 2.25rem;
            font-weight: 600;
            line-height: 1;
        }

        .btn {
            height: 60px;
            border-radius: 1rem;
            font-size: 1.25rem;
            font-weight: 600;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            user-select: none;
        }

        .btn:active {
            transform: scale(0.95);
        }

        .btn-number {
            background-color: white;
            color: #374151;
            border: 1px solid #e5e7eb;
        }

        .btn-number:hover {
            background-color: #f9fafb;
        }

        .btn-operator {
            background-color: #eef2ff;
            color: #4f46e5;
        }

        .btn-operator:hover {
            background-color: #e0e7ff;
        }

        .btn-equals {
            background-color: #4f46e5;
            color: white;
            grid-column: span 2;
        }

        .btn-equals:hover {
            background-color: #4338ca;
        }

        .btn-clear {
            background-color: #fee2e2;
            color: #dc2626;
        }

        .btn-clear:hover {
            background-color: #fecaca;
        }

        .btn-delete {
            background-color: #f3f4f6;
            color: #4b5563;
        }
    </style>
</head>
<body>

    <div class="calculator-card">
        <!-- מסך התצוגה -->
        <div class="display-screen">
            <div id="previous-display" class="previous-operand"></div>
            <div id="current-display" class="current-operand">0</div>
        </div>

        <!-- רשת הכפתורים -->
        <div class="grid grid-cols-4 gap-3">
            <button class="btn btn-clear" onclick="clearDisplay()">AC</button>
            <button class="btn btn-delete" onclick="deleteNumber()">DEL</button>
            <button class="btn btn-operator" onclick="appendOperator('/')">÷</button>
            <button class="btn btn-operator" onclick="appendOperator('*')">×</button>

            <button class="btn btn-number" onclick="appendNumber('7')">7</button>
            <button class="btn btn-number" onclick="appendNumber('8')">8</button>
            <button class="btn btn-number" onclick="appendNumber('9')">9</button>
            <button class="btn btn-operator" onclick="appendOperator('-')">-</button>

            <button class="btn btn-number" onclick="appendNumber('4')">4</button>
            <button class="btn btn-number" onclick="appendNumber('5')">5</button>
            <button class="btn btn-number" onclick="appendNumber('6')">6</button>
            <button class="btn btn-operator" onclick="appendOperator('+')">+</button>

            <button class="btn btn-number" onclick="appendNumber('1')">1</button>
            <button class="btn btn-number" onclick="appendNumber('2')">2</button>
            <button class="btn btn-number" onclick="appendNumber('3')">3</button>
            <button class="btn btn-equals" onclick="compute()">=</button>

            <button class="btn btn-number grid-cols-1" style="grid-column: span 2;" onclick="appendNumber('0')">0</button>
            <button class="btn btn-number" onclick="appendNumber('.')">.</button>
        </div>
    </div>

    <script>
        const currentDisplayElement = document.getElementById('current-display');
        const previousDisplayElement = document.getElementById('previous-display');
        
        let currentOperand = '0';
        let previousOperand = '';
        let operation = undefined;

        // הוספת מספר
        function appendNumber(number) {
            if (number === '.' && currentOperand.includes('.')) return;
            if (currentOperand === '0' && number !== '.') {
                currentOperand = number.toString();
            } else {
                currentOperand = currentOperand.toString() + number.toString();
            }
            updateDisplay();
        }

        // בחירת פעולה
        function appendOperator(op) {
            if (currentOperand === '') return;
            if (previousOperand !== '') {
                compute();
            }
            operation = op;
            previousOperand = currentOperand;
            currentOperand = '';
            updateDisplay();
        }

        // ניקוי המסך
        function clearDisplay() {
            currentOperand = '0';
            previousOperand = '';
            operation = undefined;
            updateDisplay();
        }

        // מחיקת ספרה אחרונה
        function deleteNumber() {
            if (currentOperand === '0') return;
            currentOperand = currentOperand.toString().slice(0, -1);
            if (currentOperand === '') currentOperand = '0';
            updateDisplay();
        }

        // חישוב התוצאה
        function compute() {
            let computation;
            const prev = parseFloat(previousOperand);
            const current = parseFloat(currentOperand);
            if (isNaN(prev) || isNaN(current)) return;

            switch (operation) {
                case '+':
                    computation = prev + current;
                    break;
                case '-':
                    computation = prev - current;
                    break;
                case '*':
                    computation = prev * current;
                    break;
                case '/':
                    if (current === 0) {
                        showError("שגיאה");
                        return;
                    }
                    computation = prev / current;
                    break;
                default:
                    return;
            }

            currentOperand = computation.toString();
            operation = undefined;
            previousOperand = '';
            updateDisplay();
        }

        // הצגת שגיאה (חילוק ב-0)
        function showError(msg) {
            currentOperand = msg;
            updateDisplay();
            setTimeout(clearDisplay, 1500);
        }

        // עדכון התצוגה הויזואלית
        function updateDisplay() {
            currentDisplayElement.innerText = currentOperand;
            if (operation != null) {
                const opSymbols = { '*': '×', '/': '÷', '+': '+', '-': '-' };
                previousDisplayElement.innerText = `${previousOperand} ${opSymbols[operation]}`;
            } else {
                previousDisplayElement.innerText = '';
            }
        }

        // תמיכה במקלדת
        window.addEventListener('keydown', e => {
            if (e.key >= 0 && e.key <= 9) appendNumber(e.key);
            if (e.key === '.') appendNumber('.');
            if (e.key === '=' || e.key === 'Enter') compute();
            if (e.key === 'Backspace') deleteNumber();
            if (e.key === 'Escape') clearDisplay();
            if (['+', '-', '*', '/'].includes(e.key)) appendOperator(e.key);
        });
    </script>
</body>
</html>
